{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(npm run build*)",
      "Bash(npm run typecheck*)",
      "Bash(npx tsc --noEmit*)",
      "Bash(ls *)",
      "Bash(cat CHECKPOINT.md)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(DROP TABLE*)",
      "Bash(npx prisma migrate reset*)"
    ]
  }
}
