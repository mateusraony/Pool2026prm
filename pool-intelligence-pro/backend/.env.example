# ============================================
# Pool Intelligence Pro — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================

# OBRIGATÓRIAS
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SEGURANÇA (CRÍTICO: configurar em produção)
ADMIN_SECRET=seu-segredo-aqui-minimo-32-chars

# CORS & URLs
RENDER_EXTERNAL_URL=https://seu-app.onrender.com
APP_URL=https://seu-app.onrender.com
CORS_ORIGIN=https://seu-app.onrender.com

# TELEGRAM BOT
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# INTEGRAÇÕES EXTERNAS
THEGRAPH_API_KEY=
ANTHROPIC_API_KEY=

# PUSH NOTIFICATIONS (VAPID)
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@seu-dominio.com

# CONFIGURAÇÕES OPCIONAIS (têm defaults)
CACHE_TTL_PRICE=60
CACHE_TTL_POOLS=300
CACHE_TTL_MACRO=3600
CACHE_TTL_WATCHLIST=300
MIN_LIQUIDITY=100000
MIN_VOLUME_24H=10000
MIN_POOL_AGE_DAYS=7
MAX_DIVERGENCE_PERCENT=10
ACTIVE_CHAINS=ethereum,arbitrum,base,polygon
DEFAULT_MODE=NORMAL
DEFAULT_CAPITAL=1000
REPORT_TIMEZONE=America/Sao_Paulo

# JOB INTERVALS (milliseconds)
JOB_RADAR_INTERVAL=1800000
JOB_WATCHLIST_INTERVAL=60000
JOB_SCORE_INTERVAL=300000
JOB_RECOMMENDATION_INTERVAL=3600000
JOB_ALERTS_INTERVAL=60000
JOB_HEALTH_INTERVAL=60000

# CIRCUIT BREAKER
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=300000

# RATE LIMITS (requests per minute)
RATE_LIMIT_DEFILLAMA=30
RATE_LIMIT_GECKOTERMINAL=30
RATE_LIMIT_DEXSCREENER=60
