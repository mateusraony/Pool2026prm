# Server
PORT=3001
NODE_ENV=development

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Default Settings
DEFAULT_MODE=NORMAL
DEFAULT_CAPITAL=1000
ACTIVE_CHAINS=ethereum,arbitrum,base,polygon

# Thresholds
MIN_LIQUIDITY=100000
MIN_VOLUME_24H=10000
MIN_POOL_AGE_DAYS=7
MAX_DIVERGENCE_PERCENT=10

# Cache TTLs (seconds)
CACHE_TTL_MACRO=3600
CACHE_TTL_PRICE=60
CACHE_TTL_WATCHLIST=300

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=300000

# Rate Limits (requests per minute)
RATE_LIMIT_DEFILLAMA=30
RATE_LIMIT_GECKOTERMINAL=30
RATE_LIMIT_DEXSCREENER=60

# Job Intervals (milliseconds)
JOB_RADAR_INTERVAL=1800000
JOB_WATCHLIST_INTERVAL=60000
JOB_SCORE_INTERVAL=300000
JOB_RECOMMENDATION_INTERVAL=3600000
JOB_ALERTS_INTERVAL=60000
JOB_HEALTH_INTERVAL=60000

# CORS / Deploy (Render)
APP_URL=https://your-app.onrender.com
CORS_ORIGIN=https://your-app.onrender.com

# AI Insights (Anthropic) — opcional, fallback rule-based se ausente
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Web Push (PWA Notifications) — gerado automaticamente se ausente (efêmero em produção!)
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com

# The Graph (Wallet Tracker) — opcional, demo data se ausente
THEGRAPH_API_KEY=your_thegraph_api_key
